{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Notify - valid",
      "method": "POST",
      "path": "/",
      "body": {"action": "notify", "phone": "79001234567", "patient_name": "Тест", "doctor_name": "Иванов И.И.", "date": "2026-06-01", "time": "10:00"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get appointments - missing phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "get-appointments", "phone": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Номер телефона обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get appointments - valid phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "get-appointments", "phone": "79001234567"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Cancel - missing params",
      "method": "POST",
      "path": "/",
      "body": {"action": "cancel", "phone": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Не указан ID записи или телефон"},
      "bodyMatcher": "partial"
    }
  ]
}